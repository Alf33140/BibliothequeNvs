{% extends 'base.html.twig' %}

{% block body %}
<div class="container container-home mt-5">
    <h1>Notre catalogue de livres</h1>

    <table class="table table-borderless"> 
        <tbody>
            {% for category in categories %}
              
                <tr>
                    <td colspan="3">
                        {# CORRECTION : .Categorie avec un C majuscule #}
                        <h2 class="text-primary border-bottom pb-2 mt-4">{{ category.Categorie }}</h2>
                    </td>
                </tr>

                {# Une ligne qui contiendra toutes les cards de cette catégorie #}
                <tr>
                    <td>
                        <div class="row">
                            {% for book in category.books %}
                                <div class="col-md-4 mb-4">
                                    <div class="card h-100 shadow-sm" style="width: 18rem;">
                                        {# SÉCURITÉ : On vérifie si l'image existe avant de tenter de l'afficher #}
                                        {% if book.image %}
                                            <img src="{{ asset('uploads/images/' ~ book.image) }}" 
                                                 class="card-img-top book-thumbnail img-thumbnail" 
                                                 alt="{{ book.titre }}">
                                        {% else %}
                                            <div class="bg-light text-center py-5">Pas d'image</div>
                                        {% endif %}
                                        
                                        <div class="card-body">
                                            <h5 class="card-title">{{ book.titre }}</h5>
                                            <p class="card-text"><strong>Auteur :</strong> {{ book.auteur }}</p>
                                            <p class="card-text"><small>ISBN : {{ book.isbn }}</small></p>
                                            
                                            {# COULEUR DYNAMIQUE : Rouge si stock à 0 #}
                                            <p class="card-text">
                                                Stock : <span class="{{ book.stock > 0 ? 'text-success' : 'text-danger' }}">{{ book.stock }}</span>
                                            </p>
                                            
                                            <div class="d-grid gap-2">
                                                {# On ne permet l'emprunt que si le stock est positif #}
                                                {% if book.stock > 0 %}
                                                    <a href="{{ path('app_emprunt_new', {'book_id': book.id}) }}" class="btn btn-primary">Faire un emprunt</a>
                                                {% else %}
                                                    <button class="btn btn-secondary" disabled>Rupture de stock</button>
                                                {% endif %}
                                                
                                                <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-outline-primary">Voir le détail</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="col-12">
                                    <p class="text-muted italic">Aucun livre dans cette catégorie.</p>
                                </div>
                            {% endfor %}
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}