{% extends 'base.html.twig' %}

{% block title %}Emprunt{% endblock %}

{% block body %}
    <div class="container containerForm">
        <div class="form">
            <h1>Emprunt</h1>

            <table class="table">
                <tbody>
                    <tr>
                        <th>Id</th>
                        <td>{{ emprunt.id }}</td>
                    </tr>
                    <tr>
                        <th>DateEmprunt</th>
                        <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('Y-m-d H:i:s') : '' }}</td>
                    </tr>
                    <tr>
                        <th>DateRetour</th>
                        <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('Y-m-d H:i:s') : '' }}</td>
                    </tr>
                    <tr>
                        <th>Livre</th>
                        <td>{{ emprunt.book.titre|default('Non renseigné') }}</td>
                    </tr>
                    <tr>
                        <th>Emprunteur</th>
                        <td>{{ emprunt.user.firstname }} {{ emprunt.user.lastname }}</td>
                    </tr>
                    <tr>
                        <th>Statut</th>
                        <td>
                            {% if emprunt.dateRetour %}
                                {# On compare la date de retour avec la date du jour #}
                                {% if emprunt.dateRetour < date() %}
                                    <span class="badge bg-danger">En retard</span>
                                {% else %}
                                    <span class="badge bg-success">En cours</span>
                                {% endif %}
                            {% else %}
                                <span class="badge bg-secondary">Statut inconnu</span>
                            {% endif %}
                        </td>
                    </tr>
                    
                </tbody>
            </table>
            <a href="{{ path('app_emprunt_index') }}"  class="btn btn-primary">Revenir à la liste</a>

            <a href="{{ path('app_emprunt_edit', {'id': emprunt.id}) }}"  class="btn btn-secondary">Modifier</a>

            {{ include('emprunt/_delete_form.html.twig') }}
        </div>
    </div>

    
{% endblock %}
