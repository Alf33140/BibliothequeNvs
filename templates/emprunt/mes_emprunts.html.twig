{% extends 'base.html.twig' %}

{% block title %}Mes Emprunts{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">Mon Historique de membre</h1>
    
    <div class="alert alert-info">
        Bonjour <strong>{{ app.user.lastname }}</strong>, vous avez effectué {{ emprunts|length }} emprunt(s) au total.
    </div>

    <div class="row">
        {% for emprunt in emprunts %}
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-left-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title text-primary mb-0">{{ emprunt.book.titre }}</h5>
                            
                            {# Affichage du statut avec des badges #}
                            {% if emprunt.status == 'Rendu' %}
                                <span class="badge bg-success text-white">Rendu</span>
                            {% else %}
                                <span class="badge bg-warning text-dark">En cours de lecture</span>
                            {% endif %}
                        </div>
                        <p class="text-muted mt-2 mb-1">
                            <small>Emprunté le : {{ emprunt.dateEmprunt|date('d/m/Y') }}</small>
                        </p>
                        {% if emprunt.dateRetour %}
                            <p class="mb-0">
                                <strong>À rendre avant le :</strong> {{ emprunt.dateRetour|date('d/m/Y') }}
                            </p>
                        {% endif %}
                        
                        <div class="mt-3">
                            <a href="{{ path('app_book_show', {'id': emprunt.book.id}) }}" class="btn btn-sm btn-outline-info">Fiche du livre</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="card p-5 text-center">
                    <p class="lead">Vous n'avez pas encore emprunté de livres.</p>
                    <a href="{{ path('app_home') }}" class="btn btn-primary m-auto">Découvrir le catalogue</a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}