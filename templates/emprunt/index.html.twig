{% extends 'base.html.twig' %}

{% block title %}Emprunt index{% endblock %}

{% block body %}
    <div class="container containerForm">
        <div class="form">
    
            <h1>Emprunt index</h1>

            <table class="table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>DateEmprunt</th>
                        <th>DateRetour</th>
                        <th>Livre</th>
                        <th>Status</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for emprunt in emprunts %}
                    <tr>
                        <td>{{ emprunt.id }}</td>
                        <td>{{ emprunt.dateEmprunt ? emprunt.dateEmprunt|date('Y-m-d H:i:s') : '' }}</td>
                        <td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('Y-m-d H:i:s') : '' }}</td>
                        <td>{{ emprunt.book.id }}</td>
                        <td>{{ emprunt.status }}</td>
                        <td>{{ emprunt.user.id }}</td>
                        
                        <td>
                            <a href="{{ path('app_emprunt_show', {'id': emprunt.id}) }}"  class="btn btn-primary">Visualiser</a>
                            <a href="{{ path('app_emprunt_edit', {'id': emprunt.id}) }}"  class="btn btn-secondary">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">pas d'emprunt trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
             <a href="{{ path('app_emprunt_new') }}">Créer un nouvel emprunt</a>
        </div>
    </div>
   
{% endblock %}
