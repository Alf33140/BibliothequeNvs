{% extends 'base.html.twig' %}

{% block title %}Book index{% endblock %}

{% block body %}
    <div class="container containerForm">
        <div class="form">
            <h1>Liste des Livres disponibles</h1>

            <table class="table">
                <thead>
                    <tr>
                        
                        <th>Titre</th>
                        <th>Auteur</th>
                        <th>Decription</th>
                        <th>Categorie</th>
                        <th>Isbn</th>
                        <th>Image</th>
                        <th>Stock disponible</th>
                        <th>actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for book in books %}
                    <tr>
                        
                        <td>{{ book.titre }}</td>
                        <td>{{ book.auteur }}</td>
                        <td>{{ book.description|slice(0,100) }}</td>
                        <td>{{ book.category.categorie }}</td>
                        <td>{{ book.isbn }}</td>
                        <td>{{ book.image }}</td>
                        
                        <td>
                            {% if book.stock > 0  %}
                                {{ book.stock }}
                                
                            {% else %}
                            <span class="text-danger">Pas d'emprunt possible -Plus aucun exemplaire disponible</span>
                    {% endif %}
                </td>
                        <td>
                            <a href="{{ path('app_book_show', {'id': book.id}) }}"  class="btn btn-primary">Visualiser</a>
                            <a href="{{ path('app_book_edit', {'id': book.id}) }}"  class="btn btn-secondary">Modifier</a>
                            <a href=" "  class="btn btn-secondary">Ajout de stock</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Pas de livre trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <a href="{{ path('app_book_new') }}">Create new</a>
        </div>
    </div>
{% endblock %}