{% extends 'base.html.twig' %}

{% block title %}StockLivre index{% endblock %}

{% block body %}
    <h1>StockLivre index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Livre</th>
                <th>Stock</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for stock_livre in stock_livres %}
            <tr>
                <td>{{ stock_livre.id }}</td>
                <td>{{ stock_livre.Livre }}</td>
                <td>{{ stock_livre.stock }}</td>
                <td>
                    <a href="{{ path('app_stock_livre_show', {'id': stock_livre.id}) }}">show</a>
                    <a href="{{ path('app_stock_livre_edit', {'id': stock_livre.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_stock_livre_new') }}">Create new</a>
{% endblock %}
