{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
    <div class="container containerForm">
        <div class="form">

            <h1>User index</h1>

            <table class="table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Prénom</th>
                        <th>Nom</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.email }}</td>
                        
                        {# Colonne ROLES #}
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge bg-primary">Administrateur</span> 
                            {% elseif 'ROLE_EDITOR' in user.roles %}
                                <span class="badge bg-success">Editeur</span> 
                            {% else %}
                                <span class="badge bg-secondary">Client</span> 
                            {% endif %}
                        </td>

                        <td>{{ user.firstname }}</td>
                        <td>{{ user.lastname }}</td>

                        {# Colonne ACTIONS #}
                        <td>
                            {% if 'ROLE_ADMIN' not in user.roles %}
                                {% if 'ROLE_EDITOR' not in user.roles %}
                                    <a onclick="return confirm('Voulez vous vraiment affecter ce rôle ?')" 
                                    class="btn btn-sm btn-outline-primary" 
                                    href="{{ path('app_user_change_role', {'id': user.id, 'role': 'ROLE_EDITOR'}) }}">
                                    Ajouter éditeur
                                    </a>
                                {% else %}
                                    <a onclick="return confirm('Voulez vous vraiment retirer ce rôle ?')" 
                                    class="btn btn-sm btn-outline-danger" 
                                    href="{{ path('app_user_delete_editor_role', {'id': user.id}) }}">
                                    Retirer éditeur
                                    </a>
                                {% endif %}
                                
                                <a onclick="return confirm('Supprimer cet utilisateur ?')" 
                                href="{{ path('app_user_delete', {'id': user.id}) }}" 
                                class="btn btn-sm btn-danger">Supprimer</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">no records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}